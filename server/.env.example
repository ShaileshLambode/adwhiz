# Server Configuration
PORT=4000
MONGO_URI=mongodb://localhost:27017/adwhiz

# Authentication
# Tip: Generate a secret using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here
GOOGLE_CLIENT_ID=your_google_client_id_here

# Cloudinary (Image Storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# AI APIs
RECRAFT_API_KEY=your_recraft_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Email (Nodemailer)
GMAIL_USER=your_email@gmail.com
GMAIL_PASS=your_gmail_app_password

# Instagram / Meta Social Publishing Integration
INSTAGRAM_APP_ID=your_instagram_app_id_here
INSTAGRAM_APP_SECRET=your_instagram_app_secret_here
INSTAGRAM_REDIRECT_URI=http://localhost:4000/api/social/instagram/callback
CLIENT_URL=http://localhost:5173

# Razorpay (Subscription Billing)
# Get key_id/key_secret from Dashboard > Settings > API Keys
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
# Get this from Dashboard > Settings > Webhooks when you set up the
# /api/webhooks/razorpay endpoint (use ngrok for local testing)
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here
# Create these once via Dashboard > Subscriptions > Plans (or the API) —
# one plan_id per paid tier. Free has no Razorpay plan.
RAZORPAY_PLAN_ID_BASIC=plan_xxxxxxxxxxxxx
RAZORPAY_PLAN_ID_PRO=plan_xxxxxxxxxxxxx

